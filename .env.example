# =============================================================
# AtivaMENTE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no git.
# =============================================================

# --- Firebase (copie do painel: console.firebase.google.com) ---
# Configurações → Geral → Seu App Web → firebaseConfig
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# --- ID do app (não altere) ---
VITE_APP_ID=ativamente

# --- Gemini AI (obtenha em: aistudio.google.com/app/apikey) ---
# Esta chave é APENAS para o servidor (Vercel/Netlify Function).
# Nunca use diretamente no frontend.
GEMINI_API_KEY=AIzaSy...
